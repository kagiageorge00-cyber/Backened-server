# Environment Configuration Template

# Copy this file to .env and fill in your actual values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# ============================================
# WHATSAPP CLOUD API
# ============================================
# Get these from Meta for Developers > WhatsApp Business Account
WHATSAPP_PHONE_NUMBER_ID=682624514934414
WHATSAPP_WABA_ID=YOUR_WABA_ID_HERE
WHATSAPP_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE
WHATSAPP_API_VERSION=v20.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_secure_random_token_here

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb://localhost:27017/bliss
# OR for MongoDB Atlas
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bliss

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# For Redis Cloud or similar
# REDIS_URL=redis://:password@host:port

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_key_here_make_it_strong
JWT_EXPIRE=7d

# ============================================
# EMAIL CONFIGURATION (if using email for admin)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@blissconnect.com

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE=52428800  # 50MB in bytes
UPLOAD_DIR=./uploads

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# WHATSAPP CAMPAIGN SPECIFIC
# ============================================
QUEUE_WORKER_CONCURRENCY=10
MESSAGE_RETRY_MAX=3
MESSAGE_RETRY_DELAYS=5000,30000,300000  # 5s, 30s, 5m
