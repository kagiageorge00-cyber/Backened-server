{
  "name": "bliss-travel-backend",
  "version": "1.0.0",
  "description": "Express backend for Bliss travel system",
  "main": "backend/server.js",
  "scripts": {
    "build": "mkdir -p src && cp -r backend/* src/ 2>/dev/null || (robocopy backend src /E /DCOPY:T /R:0 /W:0 >nul 2>&1 || true)",
    "start": "node backend/server.js",
    "start:prod": "node src/server.js",
    "test": "jest --runInBand tests/api.test.js backend/tests"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "amadeus": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "fluent-ffmpeg": "^2.1.3",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0"
  },
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  }
}
